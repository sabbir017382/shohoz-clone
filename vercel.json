{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist/shohoz-clone" }
    }
  ],
  "routes": [
    {
      "src": "/api/(?<resource>[^/]+)$",
      "dest": "/api/[resource].js?resource=$resource"
    },
    {
      "src": "/api/(?<resource>[^/]+)/(?<id>[^/]+)$",
      "dest": "/api/[resource]/[id].js?resource=$resource&id=$id"
    },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "functions": {
    "api/**/*.js": {
      "runtime": "nodejs18.x"
    }
  }
}